# Path to your host's Claude Code auth directory.
# Mounted into the container so the server inherits your Max-subscription session.
#
#   Windows: CLAUDE_AUTH_DIR=C:/Users/yourname/.claude
#   macOS:   CLAUDE_AUTH_DIR=/Users/yourname/.claude
#   Linux:   CLAUDE_AUTH_DIR=/home/yourname/.claude
#
CLAUDE_AUTH_DIR=

# Bearer token required by the OpenAI endpoint at /v1/chat/completions.
# Generate one with:
#   node -e "console.log('Bearer ' + require('crypto').randomBytes(24).toString('hex'))"
# Use the FULL value (including the 'Bearer ' prefix).
CLAUDE_MCP_OPENAI_AUTH_HEADER=Bearer replace-me-with-a-real-secret

# External port other devices (and you) use to reach the container.
# The container always binds internally on 3000; this only controls
# the host-side mapping. Change it without rebuilding the image.
HOST_PORT=8899
